# ==============================================================================
# SmartFlow ETL - .gitignore
# ==============================================================================

# Python
# ------------------------------------------------------------------------------
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
build/
develop-eggs/
dist/
downloads/
eggs/
.eggs/
lib/
lib64/
parts/
sdist/
var/
wheels/
share/python-wheels/
*.egg-info/
.installed.cfg
*.egg
MANIFEST

# Environments & Secrets
# ------------------------------------------------------------------------------
.env
.venv
venv/
ENV/
env/
active_env/
conda-meta/

# Testing & Linting
# ------------------------------------------------------------------------------
.ipynb_checkpoints
.pytest_cache/
.tox/
.coverage
.cache
nosetests.xml
coverage.xml
*.cover
*.log
.mypy_cache/
.ruff_cache/

# Databases & Data Files
# ------------------------------------------------------------------------------
# Ignore all SQLite, DuckDB database files
*.db
*.sqlite
*.sqlite3
*.duckdb

# Ignore raw, quarantined, or generated data files
data/raw/
data/quarantine/
data/qurantine/
data/validation_reports/
*.csv
*.parquet
*.tsv
*.xlsx

# Keep schema mapping configuration
!data/schema_mapping.json

# Dagster
# ------------------------------------------------------------------------------
.tmp_dagster_home_*
dagster_home/
dagster.yaml
dagster-storage/

# dbt (Data Build Tool)
# ------------------------------------------------------------------------------
dbt_project/target/
dbt_project/logs/
dbt_project/dbt_packages/
dbt_project/dbt_modules/
dbt_project/.user.yml
dbt_project/profiles.yml

# Operating System & IDEs
# ------------------------------------------------------------------------------
.DS_Store
Thumbs.db
.vscode/
.idea/
*.suo
*.ntvs*
*.njsproj
*.sln
*.swp
